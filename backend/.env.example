# =========================
# Render runtime
# =========================
PORT=8080
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
APP_JWT_SECRET=replace-with-a-long-random-secret

# =========================
# Database variables (choose ONE approach)
# =========================

# Approach A (recommended on Render): explicit Spring vars
# IMPORTANT: DB_URL MUST start with jdbc:mysql:// (not mysql://)
DB_URL=jdbc:mysql://<RAILWAY_PUBLIC_HOST>:<RAILWAY_PUBLIC_PORT>/<RAILWAY_DB_NAME>?useSSL=true&requireSSL=true&serverTimezone=UTC
DB_USERNAME=<RAILWAY_DB_USER>
DB_PASSWORD=<RAILWAY_DB_PASSWORD>

# Approach B: Railway-style split vars (fallback supported by app)
# MYSQLHOST=<RAILWAY_PUBLIC_HOST>
# MYSQLPORT=<RAILWAY_PUBLIC_PORT>
# MYSQLDATABASE=<RAILWAY_DB_NAME>
# MYSQLUSER=<RAILWAY_DB_USER>
# MYSQLPASSWORD=<RAILWAY_DB_PASSWORD>

# Optional
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect
